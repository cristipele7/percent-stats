generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

generator nestgraphql {
  provider                = "prisma-nestjs-graphql"
  output                  = "../@generated/types"
  reExport                = Directories
  purgeOutput             = false
  combineScalarFilters    = true
  noAtomicOperations      = true
  // field validator
  fields_Validator_input  = true
  fields_Validator_output = true
  fields_Validator_model  = true
  fields_Validator_from   = "class-validator"
  // Args where|data nested validator
  decorate_1_type         = "*Args"
  decorate_1_field        = "@(data|where)"
  decorate_1_name         = ValidateNested
  decorate_1_from         = "class-validator"
  decorate_1_arguments    = "[]"
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  /// @Validator.IsEnum(UserType)
  type UserType

  /// @Validator.IsString()
  name String
}

model Country {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  /// @Validator.IsString()
  name String @unique

  leagues League[]
  teams   Team[]
}

model League {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  /// @Validator.@IsNumber()
  apiId Float @unique

  /// @Validator.IsString()
  name String

  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId String

  matches Match[]
}

model Team {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  /// @Validator.@IsNumber()
  apiId Float @unique

  /// @Validator.IsString()
  name String

  /// @Validator.IsBoolean()
  synced Boolean @default(false)

  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId String

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  /// @Validator.@IsNumber()
  apiId Float @unique

  /// @Validator.IsDate()
  date DateTime

  /// @Validator.@IsInt()
  round Int

  /// @Validator.IsEnum(MatchState)
  state MatchState

  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leagueId String

  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  homeTeamId String

  /// @Validator.@IsInt()
  homeTeamGoals Int

  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  awayTeamId String

  /// @Validator.@IsInt()
  awayTeamGoals Int
}

enum UserType {
  ADMIN
  CLIENT
}

enum MatchState {
  NOT_STARTED
  FIRST_HALF
  HALF_TIME
  SECOND_HALF
  FULL_TIME
}
